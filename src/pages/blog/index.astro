---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import CTASection from '../../components/CTASection.astro';
import Footer from '../../components/Footer.astro';
import { blogPosts } from '../../data/blog-posts';

const breadcrumbs = [
  { name: 'Startseite', url: '/' },
  { name: 'Blog', url: '/blog' },
];
---

<Layout
  title="Blog - Paulo Ferreira | Digitales Marketing & Webdesign"
  description="Aktuelle Beiträge zu Webdesign, Framer Templates, UX/UI Design und digitalem Marketing von Paulo Ferreira."
  breadcrumbs={breadcrumbs}
>
  <Navbar />
  <main id="main-content" class="pt-28 pb-12 px-6">
    <div class="max-w-6xl mx-auto">
      <!-- Breadcrumb navigation -->
      <nav aria-label="Breadcrumb" class="mb-6">
        <ol class="flex items-center gap-2 text-sm text-[var(--color-text-muted)]">
          {breadcrumbs.map((crumb, i) => (
            <li class="flex items-center gap-2">
              {i > 0 && <span aria-hidden="true">/</span>}
              {i === breadcrumbs.length - 1 ? (
                <span aria-current="page" class="text-[var(--color-text-secondary)]">{crumb.name}</span>
              ) : (
                <a href={crumb.url} class="hover:text-white transition-colors">{crumb.name}</a>
              )}
            </li>
          ))}
        </ol>
      </nav>

      <h1 class="text-3xl font-light text-[var(--color-text-muted)] mb-10 reveal">Blog</h1>
      <div class="flex flex-col">
        {blogPosts.map((post, i) => (
          <a
            href={`/blog/${post.slug}`}
            class="blog-card flex flex-col sm:flex-row items-start sm:items-center gap-6 py-6 border-b border-white/10 reveal"
            data-delay={String(i * 80)}
          >
            <div class="w-full sm:w-32 h-24 rounded-lg overflow-hidden flex-shrink-0">
              <img
                src={post.image}
                alt={post.title}
                class="w-full h-full object-cover transition-transform duration-500"
                width="128"
                height="96"
                loading="lazy"
              />
            </div>
            <div>
              <time class="text-sm text-[var(--color-text-muted)] mb-1 block" datetime={post.dateISO}>{post.date}</time>
              <h2 class="text-lg font-medium hover:text-white/80 transition-colors">{post.title}</h2>
              <p class="text-sm text-[var(--color-text-muted)] mt-1">{post.readingTime} Min. Lesezeit</p>
            </div>
          </a>
        ))}
      </div>
    </div>
    <CTASection />
  </main>
  <Footer />
</Layout>
