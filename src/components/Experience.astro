---
const experiences = [
  { role: 'Design Lead', company: 'Geonode', period: 'Jan 2020 - Jan 2023' },
  { role: 'Lead UX/UI Designer', company: 'Truely', period: 'Jan 2018 - Jan 2020' },
  { role: 'Senior Product Designer', company: 'Nicey Consulting', period: 'Jun 2016 - Present' },
  { role: 'Co-Founder', company: 'BrandingMag', period: 'Jan 2011 - Jun 2015' },
];
---

<section class="py-20 px-6 reveal">
  <div class="max-w-6xl mx-auto">
    <h2 class="text-3xl font-light text-[var(--color-text-muted)] mb-10">Experience</h2>
    <div class="flex flex-col">
      {experiences.map((exp, i) => (
        <div
          class="flex flex-col md:flex-row md:items-center justify-between py-6 border-b border-white/10 reveal"
          data-delay={String(i * 100)}
        >
          <h3 class="text-xl md:text-2xl font-light text-[var(--color-text-secondary)]">{exp.role}</h3>
          <div class="text-right mt-2 md:mt-0">
            <p class="text-lg md:text-xl font-semibold">{exp.company}</p>
            <p class="text-sm text-[var(--color-text-muted)]">{exp.period}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
