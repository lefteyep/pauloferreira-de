---

<section class="py-24 px-6 reveal" aria-label="Kontakt aufnehmen">
  <div class="max-w-6xl mx-auto flex justify-center">
    <div class="cta-blob w-full max-w-2xl px-12 py-20 flex flex-col items-center text-center">
      <h2 class="text-3xl md:text-4xl font-semibold mb-8 leading-tight">
        Bereit für mehr Kunden und Umsatz?
      </h2>
      <a
        href="mailto:kontakt@pauloferreira.de"
        class="btn-primary inline-flex items-center gap-2 px-7 py-3.5 bg-black/30 text-white rounded-full font-medium text-sm border border-white/10 hover:bg-black/40 mb-6"
      >
        <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path d="M12 2L9.19 8.63L2 9.24l5.46 4.73L5.82 21L12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2z"/>
        </svg>
        Jetzt Beratung anfragen
      </a>
      <div class="flex items-center gap-3">
        <img
          src="/images/avatar.jpg"
          alt="Paulo Ferreira"
          class="w-8 h-8 rounded-full object-cover"
          width="32"
          height="32"
          loading="lazy"
        />
        <span class="text-sm text-white/70">Paulo Ferreira - Branding & Marketing</span>
      </div>
    </div>
  </div>
</section>
