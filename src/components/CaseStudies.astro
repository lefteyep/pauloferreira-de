---
const caseStudies = [
  {
    title: 'Modernizing a Subscription Management Platform',
    description: 'With a user-centered approach, the goal was to create an intuitive interface for effortless subscription management while incorporating gamification elements.',
    image: '/images/case-study-1.jpg',
    stats: [
      { label: 'Engagement', value: '12', suffix: ' min' },
      { label: 'User Satisfaction', value: '4.5', suffix: '*' },
    ],
  },
  {
    title: 'Revamping an E-Commerce Website',
    description: 'Focus was to create a user-friendly interface that simplified the shopping experience and increased conversion rates through optimized checkout flows.',
    image: '/images/case-study-2.jpg',
    stats: [
      { label: 'Usability', value: '85', suffix: '%' },
      { label: 'User Retention', value: '70', suffix: '%' },
    ],
  },
  {
    title: 'Developing a Fintech Data Dashboard',
    description: 'Leading data visualization and stats platform. Live price action, real-time on-chain data monitoring, and comprehensive analytics dashboard.',
    image: '/images/case-study-3.jpg',
    stats: [
      { label: 'Conversion Rate', value: '12', suffix: '%' },
      { label: 'User Satisfaction', value: '4.8', suffix: '*' },
    ],
  },
  {
    title: 'Building a Peer-to-Peer Network App',
    description: 'An innovative app enabling users to share unused internet bandwidth. Designed for simplicity, powerful functionality, and seamless monetization.',
    image: '/images/case-study-4.jpg',
    stats: [
      { label: 'Conversion Rate', value: '20', suffix: '%' },
      { label: 'User Satisfaction', value: '95', suffix: '%' },
    ],
  },
];
---

<section id="case-study" class="py-20 px-6" aria-label="Fallstudien">
  <div class="max-w-6xl mx-auto flex flex-col gap-8">
    <h2 class="text-3xl font-light text-[var(--color-text-muted)] mb-2">Lösungen & Projekte</h2>
    {caseStudies.map((study, i) => (
      <article class="glass-card p-8 md:p-10 reveal" data-delay={String(i * 100)}>
        <div class="flex flex-col md:flex-row gap-8 items-start">
          <div class="flex-1">
            <h3 class="text-2xl md:text-3xl font-semibold mb-4 leading-tight">{study.title}</h3>
            <p class="text-[var(--color-text-secondary)] text-sm leading-relaxed max-w-md">{study.description}</p>
          </div>
          <div class="flex-1">
            <img
              src={study.image}
              alt={`Fallstudie: ${study.title}`}
              class="w-full rounded-lg object-cover aspect-video"
              width="600"
              height="338"
              loading="lazy"
            />
            <div class="flex gap-12 mt-6">
              {study.stats.map(stat => (
                <div>
                  <p class="text-sm text-[var(--color-text-secondary)] mb-1">{stat.label}</p>
                  <p
                    class="text-3xl md:text-4xl font-bold"
                    data-counter
                    data-target={stat.value}
                    data-suffix={stat.suffix}
                  >
                    0{stat.suffix}
                  </p>
                </div>
              ))}
            </div>
          </div>
        </div>
      </article>
    ))}
  </div>
</section>
